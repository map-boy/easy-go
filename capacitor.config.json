{
  "appId": "com.easygo.rwanda",
  "appName": "Easy GO",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "*.supabase.co",
      "*.openstreetmap.org",
      "*.tile.openstreetmap.org",
      "*.arcgisonline.com",
      "*.cartocdn.com",
      "*.project-osrm.org",
      "photon.komoot.io",
      "*.mtn.com"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0a0a",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#0a0a0a",
    "appendUserAgent": "EasyGO-Android"
  }
}